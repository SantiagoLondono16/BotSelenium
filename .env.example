# ══════════════════════════════════════════════════════════════════════════════
# Environment variables for the RPA Extraction API
#
# Copy this file to .env and fill in the values marked with <REPLACE>.
# The .env file is listed in .gitignore and must never be committed.
#
# Required vs Optional
# ─────────────────────
#   REQUIRED  — the application will not start without this value.
#   OPTIONAL  — a safe default is used if the variable is absent.
# ══════════════════════════════════════════════════════════════════════════════


# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# These are passed directly to both the `db` container and to app/core/config.py.
# app/core/config.py assembles DATABASE_URL automatically from these parts.

POSTGRES_USER=rpa_user                  # REQUIRED — DB login username
POSTGRES_PASSWORD=<REPLACE>             # REQUIRED — DB login password (no defaults here)
POSTGRES_DB=rpa_db                      # REQUIRED — database name to create/use
POSTGRES_HOST=db                        # OPTIONAL — hostname; "db" = docker-compose service name
POSTGRES_PORT=5432                      # OPTIONAL — default PostgreSQL port


# ── Portal credentials ─────────────────────────────────────────────────────────
# Used exclusively by the Selenium RPA bot (app/rpa/login.py).
# These are never logged or exposed through the API.

PORTAL_URL=<REPLACE>                    # REQUIRED — full URL of the web portal, e.g. https://portal.example.com
PORTAL_USERNAME=<REPLACE>              # REQUIRED — portal login username
PORTAL_PASSWORD=<REPLACE>              # REQUIRED — portal login password


# ── Selenium ───────────────────────────────────────────────────────────────────

SELENIUM_REMOTE_URL=http://selenium:4444/wd/hub
                                        # OPTIONAL — WebDriver Grid URL
                                        #   "http://selenium:4444/wd/hub"  inside Docker Compose
                                        #   "http://localhost:4444/wd/hub" for a local grid

SELENIUM_TIMEOUT_SECONDS=30            # OPTIONAL — maximum seconds for each explicit wait

SELENIUM_HEADLESS=true                 # OPTIONAL — run Chrome without a visible window
                                        #   set to "false" to enable the VNC viewer on port 7900


# ── RPA concurrency ────────────────────────────────────────────────────────────

RPA_MAX_WORKERS=2                       # OPTIONAL — max parallel bot threads
                                        #   must be ≤ SE_NODE_MAX_SESSIONS on the Selenium node
                                        #   increase with caution (each thread opens a browser)


# ── Application ────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO                          # OPTIONAL — DEBUG | INFO | WARNING | ERROR
APP_ENV=development                     # OPTIONAL — development | production
                                        #   "development" enables SQLAlchemy echo logging
